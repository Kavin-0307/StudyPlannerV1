package com.Ajwain.SOS.controllers;

import java.util.List;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.Ajwain.SOS.dto.DeadlineRequestDTO;
import com.Ajwain.SOS.dto.DeadlineResponseDTO;
import com.Ajwain.SOS.services.DeadlineService;

@RestController
@RequestMapping("/api/deadlines")
public class DeadlineController {
	private final DeadlineService deadlineService;
	public DeadlineController(DeadlineService deadlineService) {
		this.deadlineService=deadlineService;
	}
	@PostMapping("/{subjectId}")
	public ResponseEntity<DeadlineResponseDTO> createDeadline(@PathVariable Long subjectId,@RequestBody DeadlineRequestDTO dto){
		return ResponseEntity.status(HttpStatus.CREATED).body(deadlineService.createDeadline(subjectId, dto));
	}
	@GetMapping("/user/{userId}")
	public ResponseEntity<List<DeadlineResponseDTO>> getDeadlinesByUser(@PathVariable Long userId){
		return ResponseEntity.ok(deadlineService.getDeadlinesByUser(userId));
	}
	@GetMapping("/subject/{subjectId}")
	public ResponseEntity<List<DeadlineResponseDTO>> getDeadlinesBySubject(@PathVariable long subjectId){
		return ResponseEntity.ok(deadlineService.getDeadlinesBySubject(subjectId));
	}
	@GetMapping("/upcoming/{userId}")
	public ResponseEntity<List<DeadlineResponseDTO>> getUpcomingDeadlines(@PathVariable Long userId){
		return ResponseEntity.ok(deadlineService.getUpcomingDeadlines(userId));
	}
	@PutMapping("/{deadlineId}")
	public ResponseEntity<DeadlineResponseDTO> updateDeadline(@PathVariable long deadlineId,@RequestBody DeadlineRequestDTO dto){
		return ResponseEntity.ok(deadlineService.updateDeadline(deadlineId, dto));
	}
	@PostMapping("/{deadlineId}")
	public void delete() {
		
	}
	
}
