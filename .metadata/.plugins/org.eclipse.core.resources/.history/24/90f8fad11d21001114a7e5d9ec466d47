package com.Ajwain.SOS.entities;

import java.time.LocalDateTime;

import jakarta.persistence.*;
import jakarta.validation.constraints.Future;

public class Deadline {
	@Id
	@GeneratedValue(strategy=GenerationType.IDENTITY)
	private long id;
	
	@ManyToOne(fetch=FetchType.LAZY,optional=false)
	@JoinColumn(name="subject_name",nullable=false)
	private Subject subject;
	
	@Column(name="title",nullable=false)
	private String deadlineTitle;
	
	@Future
	@Column(name="deadline_date",nullable=false)
	private LocalDateTime deadlineDate;
	
	@Column(name="type")
	private DeadlineType deadlineType;
	
	@Column(name="deadline_priority",nullable=false)
	private int deadlinePriority;
	
	public long getId() {
		return id;
	}
	public Subject setSubject(Subject subject) {
		this.subject=subject;
	}
	
	
}
