package com.Ajwain.SOS.services;

import org.springframework.stereotype.Service;

import com.Ajwain.SOS.repositories.LectureRepository;

@Service
public class AnalyticsService {
	private final LectureRepository lectureRepository;
	public AnalyticsService(LectureRepository lectureRepository) {
		this.lectureRepository=lectureRepository;
	}
	public Long getCompletedLectures(Long userId) {
		return lectureRepository.countProcessedLecturesByUserId(userId);
	}
	public Long getPendingLectures(Long userID) {
		return lectureRepository.countPendingLecturesByUserId(userID);
	}
}
