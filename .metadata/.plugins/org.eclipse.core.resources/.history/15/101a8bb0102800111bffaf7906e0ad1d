package com.Ajwain.SOS.specifications;

import java.time.LocalDateTime;

import org.springframework.data.domain.Sort;
import org.springframework.data.jpa.domain.Specification;

import com.Ajwain.SOS.entities.Deadline;
import com.Ajwain.SOS.entities.enums.DeadlineType;

public class DeadlineSpecification {
	public static Specification<Deadline> hasKeyword(String keyword){
		return(root,query,cb)->{
			if(keyword==null||keyword.isBlank())
				return cb.conjunction();
			else
				return cb.like(cb.lower(root.get("deadlineTitle")), "%" + keyword.toLowerCase() + "%");
		};
	}
	public static Specification<Deadline> hasSubject(Long subjectId){
		return(root,query,cb)->{
			if(subjectId!=null) {
				return cb.equal(root.get("subject").get("id"),subjectId);
			}
			else
				 return cb.conjunction();
		};
	}

	public static Specification<Deadline> deadlineAfter(LocalDateTime localDateTime){
		return (root,query,cb)->{
			if(localDateTime==null)
				return cb.conjunction();
			else
				return cb.greaterThanOrEqualTo(root.get("deadlineDate"),localDateTime);
		};
	}
	public static Specification<Deadline> deadlineBefore(LocalDateTime toDate){
		return (root,query,cb)->{
			if(toDate==null)
				return cb.conjunction();
			else
				return cb.lessThanOrEqualTo(root.get("deadlineDate"),toDate);
		};
	}
	public static Specification<Deadline> hasPriority(Integer deadlinePriority){
		return (root,query,cb)->{
			if(deadlinePriority==null)
				return cb.conjunction();
			else
				return cb.equal(root.get("deadlinePriority"),deadlinePriority);
		};
	}
	public static Sort hasType(DeadlineType deadlineType) {
		// TODO Auto-generated method stub
		return null;
	}
}
