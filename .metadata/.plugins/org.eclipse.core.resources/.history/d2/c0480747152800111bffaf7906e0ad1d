package com.Ajwain.SOS.specifications;

import java.time.LocalDate;
import java.time.LocalDateTime;

import org.springframework.data.domain.Sort;
import org.springframework.data.jpa.domain.Specification;

import com.Ajwain.SOS.entities.Deadline;
import com.Ajwain.SOS.entities.Revision;
import com.Ajwain.SOS.entities.enums.DeadlineType;
import com.Ajwain.SOS.entities.enums.RevisionStatus;

public class RevisionSpecification {
	public static Specification<Revision> hasUser(Long userId){
		return(root,query,cb)->{
			if(userId==null)
				return cb.conjunction();
			else
				return cb.equal(root.get("lecture").get("subject").get("user").get("id"),userId);
		};
	}
	public static Specification<Revision> hasLecture(Long lectureId){
		return(root,query,cb)->{
			if(lectureId!=null) {
				return cb.equal(root.get("lecture").get("id"),lectureId);
			}
			else
				 return cb.conjunction();
		};
	}

	public static Specification<Revision> hasStatus(RevisionStatus status){
		return (root,query,cb)->{
			if(status==null)
				return cb.conjunction();
			else
				return cb.equal(root.get("status"),status);
		};
	}
	
	public static Specification<Revision> hasRevisionNumber(Integer revisionNumber){
		return (root,query,cb)->{
			if(revisionNumber==null)
				return cb.conjunction();
			else
				return cb.equal(root.get("revisionNumber"),revisionNumber);
		};
	}
	public static Specification<Revision> revisionAfter(LocalDate fromDate){
		return (root,query,cb)->{
			if(fromDate==null)
				return cb.conjunction();
			else
				return cb.equal(root.get("fromDate"),fromDate);
		};
	}
	public static Specification<Deadline> deadlineBefore(LocalDateTime toDate){
		return (root,query,cb)->{
			if(toDate==null)
				return cb.conjunction();
			else
				return cb.lessThanOrEqualTo(root.get("deadlineDate"),toDate);
		};
	}
}
