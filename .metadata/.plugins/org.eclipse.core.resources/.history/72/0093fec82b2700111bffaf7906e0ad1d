package com.Ajwain.SOS.config;

import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.web.config.PageableHandlerMethodArgumentResolverCustomizer;

@Configuration
public class PaginationConfig {
	private static final int DEFAULT_SIZE=20;
	private static final int MAX_SIZE=50;
	@Bean
	public PageableHandlerMethodArgumentResolverCustomizer customizePagination() {
		return resolver->{
			resolver.setMaxPageSize(MAX_SIZE);
			resolver.setOneIndexedParameters(false);//page starts from 0
			resolver.setFallbackPageable(org.springframework.data.domain.PageRequest.of(0,DEFAULT_SIZE));
		};
	}
	public int getDefaultSize() {
		return DEFAULT_SIZE;
	}
	public int getMaxSize() {
		return MAX_SIZE;
	}
}
