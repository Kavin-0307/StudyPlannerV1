package com.Ajwain.SOS.services;

import java.time.LocalDate;

import org.springframework.stereotype.Service;

import com.Ajwain.SOS.entities.enums.StudyStatus;
import com.Ajwain.SOS.repositories.LectureRepository;
import com.Ajwain.SOS.repositories.StudyPlanRepository;

@Service
public class AnalyticsService {
	private final LectureRepository lectureRepository;
	private final StudyPlanRepository studyPlanRepository;
	public AnalyticsService(LectureRepository lectureRepository,StudyPlanRepository studyPlanRepository) {
		this.lectureRepository=lectureRepository;
		this.studyPlanRepository=studyPlanRepository;
	}
	public Long getCompletedLectures(Long userId) {
		return lectureRepository.countProcessedLecturesByUserId(userId);
	}
	public Long getPendingLectures(Long userID) {
		return lectureRepository.countPendingLecturesByUserId(userID);
	}
	public Long getStudyProgressPercentage(Long userId) {
		long totalPlans=studyPlanRepository.countByUserId(userId);
		if(totalPlans==0)
			return 0L;
		long completedPlans=studyPlanRepository.countByUserIdAndStatus(userId, StudyStatus.COMPLETED);
		return Math.round(((double)completedPlans/totalPlans)*100);
	}
	  public Long getStudyHoursThisWeek(Long userId) {
	        LocalDate today = LocalDate.now();
	        LocalDate weekAgo = today.minusDays(7);

	        Long hours= studyPlanRepository.sumStudyHoursBetweenDates(userId, weekAgo, today);
	        return hours != null ? hours : 0L;
	  }
}
